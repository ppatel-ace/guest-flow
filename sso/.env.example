# ── Required ──────────────────────────────────────────────────────────────────

# Supabase / PostgreSQL connection string (same DB used by GuestFlow)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres?sslmode=require

# JWT signing secret — generate with:  openssl rand -hex 32
# Must be IDENTICAL to the SSO_JWT_SECRET value in GuestFlow's .env
SSO_JWT_SECRET=

# Public base URL of this SSO service
SSO_BASE_URL=https://sso.aceelectronics.com

# Shared cookie domain (without leading dot — the service adds it automatically)
APP_DOMAIN=aceelectronics.com

# ── First-start admin seed (only applies when no users exist yet) ─────────────

INITIAL_ADMIN_EMAIL=admin@aceelectronics.com
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=Admin

# ── Microsoft Entra ID GCC High — SSO login (defaults already set) ────────────

# AZURE_CLIENT_ID=443420ec-3e93-4fe2-b233-ee23866d66b1
# AZURE_TENANT_ID=6ab850db-8359-47f8-9e46-ddb57a3f87bd

# ── SMTP — password reset emails ──────────────────────────────────────────────

SMTP_HOST=smtp.office365.us
SMTP_PORT=587
SMTP_FROM=no-reply@aceelectronics.com

# OAuth 2.0 / XOAUTH2 (GCC High — recommended, takes priority over basic auth)
SMTP_OAUTH_CLIENT_ID=a511d309-02a3-4ee9-b501-e1ec914579ca
SMTP_OAUTH_TENANT_ID=6ab850db-8359-47f8-9e46-ddb57a3f87bd
SMTP_OAUTH_CLIENT_SECRET=
SMTP_OAUTH_SCOPE=https://outlook.office365.us/.default

# Basic-auth fallback (only used if OAuth vars above are not set)
# SMTP_USER=
# SMTP_PASS=
